# ─────────── App ───────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:8080

# ─────────── Database ───────────
DATABASE_URL=postgresql://ks:ks@localhost:5432/kscsm?schema=public

# ─────────── Redis (BullMQ + cache) ───────────
REDIS_URL=redis://localhost:6379

# ─────────── JWT ───────────
JWT_SECRET=change-me-to-64-random-bytes-in-production
JWT_REFRESH_SECRET=change-me-to-64-random-bytes-refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────── Baileys ───────────
# Pasta onde o authState das sessões é persistido (volume Docker)
BAILEYS_AUTH_DIR=./data/sessions
# Browser shown to WhatsApp
BAILEYS_BROWSER_NAME=KS CSM
BAILEYS_BROWSER_VERSION=1.0.0

# ─────────── Anti-ban ───────────
# Delay mínimo entre mensagens (ms)
ANTIBAN_MIN_DELAY_MS=3000
# Delay máximo entre mensagens (ms) — jitter real entre MIN e MAX
ANTIBAN_MAX_DELAY_MS=8000
# Quantas mensagens antes de forçar pausa longa
ANTIBAN_PAUSE_AFTER=80
# Pausa longa (ms) após ANTIBAN_PAUSE_AFTER mensagens
ANTIBAN_LONG_PAUSE_MS=300000
# Limite por minuto / hora / dia (defesa)
ANTIBAN_RATE_PER_MINUTE=8
ANTIBAN_RATE_PER_HOUR=200
ANTIBAN_RATE_PER_DAY=1500
# Simular digitando antes de enviar (ms)
ANTIBAN_TYPING_MS_MIN=800
ANTIBAN_TYPING_MS_MAX=2500
# Warm-up: número de dias que novas sessões ficam em modo limitado
ANTIBAN_WARMUP_DAYS=3

# ─────────── Uploads ───────────
UPLOAD_DIR=./data/uploads
UPLOAD_MAX_MB=50

# ─────────── Admin seed ───────────
SEED_ADMIN_EMAIL=admin@kscsm.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin
